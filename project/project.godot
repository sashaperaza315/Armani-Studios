; Engine configuration file.
; Godot 4.x project — Hollowhunt: The Forgotten Orchard (Sprint 0)
; Open this file's parent folder ("project/") in Godot 4 to load the project.

config_version=5

[application]

config/name="Hollowhunt - The Forgotten Orchard"
run/main_scene="res://scenes/environments/forgotten_orchard/forgotten_orchard.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[autoload]

InputSetup="*res://scripts/systems/input_setup.gd"
GameManager="*res://scripts/systems/game_manager.gd"

[rendering]

renderer/rendering_method="forward_plus"
